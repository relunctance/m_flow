# =============================================================================
# PIPELINE TUNING
# =============================================================================
#
# GRAPH_CONSTRUCTION_CONCURRENCY=4          # parallel workers for graph building
# RETRIEVAL_TOP_K=10                        # default top-K for vector search
# CHUNK_OVERLAP_TOKENS=128                  # overlap between text chunks
# CHUNK_MAX_TOKENS=1024                     # max tokens per chunk
# PIPELINE_RETRY_ATTEMPTS=3                 # retries on transient pipeline errors
#
# --- Memory Pipeline Feature Defaults ---
# These set the SERVER-WIDE defaults. Users can still override per-request via API/UI.
#
# MFLOW_CONTENT_ROUTING=true               # Sentence-level topic classification within chunks.
#                                          # Enable when text may contain multiple topics per chunk.
#                                          # Cost: +1 LLM call per multi-sentence chunk.
#
# MFLOW_EPISODIC_ENABLE_ROUTING=true       # Merge new content into existing related episodes.
#                                          # Disable for faster independent-document ingestion.
#                                          # Cost: +vector search + LLM decision per document.
#
# MFLOW_EPISODE_SIZE_CHECK_AUTO=true       # Post-memorize check that splits oversized episodes.
#                                          # Recommended when episode routing is enabled.
#
# MFLOW_PROCEDURAL_ENABLED=false           # Extract reusable procedures/preferences (experimental).
#                                          # Complements episodic facts with abstract knowledge.
#                                          # Cost: +LLM calls for procedural extraction.
#
# MFLOW_PRECISE_MODE=false                 # Zero-loss summarization for contracts, financials, etc.
#                                          # Preserves ALL dates, numbers, names, constraints.
#                                          # Cost: significantly more LLM tokens per chunk.
#
# MFLOW_AUTO_DETECT_DIALOG=true            # Auto-detect chat/meeting content and switch to
#                                          # speaker-turn splitting. Disable for explicit control.
#
# MFLOW_LLM_CONCURRENCY_LIMIT=20          # Max concurrent LLM API calls.
# MFLOW_EMBEDDING_CONCURRENCY=20           # Max concurrent embedding API calls.
# MFLOW_PIPELINE_CONCURRENCY=              # Item-level concurrency (auto: SQLite=1, PG=20).
#
# --- Logging ---
# LOG_FILE_LEVEL=DEBUG                     # File log level (default: DEBUG). Set to INFO
#                                          # to reduce log file size from GB to MB.
# LOG_FILE_MAX_BYTES=100000000             # Max log file size before rotation (100MB).
# LOG_FILE_BACKUP_COUNT=5                  # Number of rotated log files to keep.


# =============================================================================
# PLAYGROUND (face recognition integration)
# =============================================================================
#
# Required when using the Playground with fanjing-face-recognition.
# Both M-flow and fanjing-face-recognition must share the same key.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# FACE_API_KEY=""


