# =============================================================================
# M-FLOW ENVIRONMENT CONFIGURATION
# =============================================================================
#
# Quickstart: set MFLOW_LLM_API_KEY (or LLM_API_KEY for compat) and you're good to go.
# All variables support MFLOW_ prefix (preferred) with bare-name fallback.
# Defaults -- SQLite (relational), LanceDB (vector), Kuzu (graph).
# All defaults are file-based; no external services required for local dev.
# Data is stored in .venv by default.
#
# Service lifecycle (recommended):
#   ./scripts/manage_service.sh start | stop | restart | status
# Always use graceful shutdown to avoid database lock issues.
# On restart, stale locks are cleaned up automatically.
# =============================================================================


# =============================================================================
# RUNTIME
# =============================================================================

ENV="local"                                 # deployment environment tag
TOKENIZERS_PARALLELISM="false"              # avoid HuggingFace tokenizer fork warnings
LITELLM_LOG="ERROR"                         # LiteLLM log level (DEBUG, INFO, WARNING, ERROR)
# TELEMETRY_DISABLED=1                      # set to 1 to opt out of anonymous telemetry
# DEFAULT_USER_EMAIL=""                     # seed user email
# DEFAULT_USER_PASSWORD=""                  # seed user password


# =============================================================================
# ACCESS CONTROL
# =============================================================================

# --- environment mode ---
# Controls whether default secrets are allowed.
# Permissive: development | dev | local
# Strict (requires explicit secrets): production | staging | test
# MFLOW_ENV="production"

# --- JWT secrets (REQUIRED outside dev/local) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# FASTAPI_USERS_JWT_SECRET="your-secure-random-secret-here"
# FASTAPI_USERS_RESET_PASSWORD_TOKEN_SECRET="your-secure-random-secret-here"
# FASTAPI_USERS_VERIFICATION_TOKEN_SECRET="your-secure-random-secret-here"

REQUIRE_AUTHENTICATION=False                # set True to protect API with auth
ENABLE_BACKEND_ACCESS_CONTROL=false          # per-user+dataset DB isolation (SQLite, Postgres, LanceDB, KuzuDB)
ACCEPT_LOCAL_FILE_PATH=True                 # False when M-flow is a headless backend
ALLOW_HTTP_REQUESTS=True                    # False to block outbound HTTP (SSRF protection)
ALLOW_CYPHER_QUERY=True                     # False to disable raw Cypher queries
RAISE_INCREMENTAL_LOADING_ERRORS=True       # False to swallow errors on faulty documents


# =============================================================================
# LANGUAGE MODELS
# =============================================================================

STRUCTURED_OUTPUT_FRAMEWORK="instructor"    # instructor | baml

LLM_API_KEY="sk-cp-l1UXzfDi_GPU6AHMWmY_fqEbuzoNh9-rpKB6NevoN2TFfeeLX__xaqA5-AqrS8woLEij1NqHt_dpbx4mNf9UXv86o-wONDPZvFPK0jjXxI1CN7-lc3lmUFw"
LLM_MODEL="MiniMax-M2.7"
LLM_PROVIDER="minimax"
LLM_ENDPOINT="https://api.minimaxi.com/anthropic"                             # override base URL (leave blank for default)
LLM_API_VERSION=""                          # API version string (Azure, etc.)
LLM_MAX_TOKENS="***"                      # max output tokens
LLM_INSTRUCTOR_MODE=""                      # override Instructor extraction mode (provider-specific defaults apply)

# --- Alternative LLM providers (M-flow exclusive) ---
# DeepSeek:  LLM_PROVIDER="custom"  LLM_MODEL="deepseek/deepseek-chat"  LLM_ENDPOINT="https://api.deepseek.com/v1"
